#!/usr/bin/env bash
set -euo pipefail

REPO="colbymchenry/codegraph"
INSTALL_DIR="${CODEGRAPH_INSTALL_DIR:-$HOME/.codegraph}"
BIN_DIR="${CODEGRAPH_BIN_DIR:-$HOME/.local/bin}"
PINNED_VERSION="${CODEGRAPH_VERSION:-}"

die() { echo "update-codegraph: error: $*" >&2; exit 1; }

command -v curl >/dev/null || die "curl is required"
command -v tar  >/dev/null || die "tar is required"

# Detect platform -> target triple matching the release archives.
os="$(uname -s)"
arch="$(uname -m)"
case "$os" in
  Darwin) os="darwin" ;;
  Linux)  os="linux" ;;
  *) die "unsupported OS: $os" ;;
esac
case "$arch" in
  arm64|aarch64) arch="arm64" ;;
  x86_64|amd64)  arch="x64" ;;
  *) die "unsupported architecture: $arch" ;;
esac
target="${os}-${arch}"

# Resolve the version: prefer the releases/latest web redirect (no API rate
# limit), fall back to the API. Honor CODEGRAPH_VERSION if pinned.
version="$PINNED_VERSION"
if [ -z "$version" ]; then
  version="$(curl -fsSLI -o /dev/null -w '%{url_effective}' \
    "https://github.com/$REPO/releases/latest" \
    | sed -n 's#.*/releases/tag/##p')"
fi
if [ -z "$version" ]; then
  version="$(curl -fsSL "https://api.github.com/repos/$REPO/releases/latest" \
    | sed -n 's/.*"tag_name": *"\([^"]*\)".*/\1/p' | head -n1)"
fi
[ -n "$version" ] || die "could not resolve latest version; set CODEGRAPH_VERSION (e.g. v1.1.6)"
case "$version" in v*) ;; *) version="v$version" ;; esac

echo "Latest release: $version ($target)"

BASE="https://github.com/$REPO/releases/download/$version"
ASSET="codegraph-${target}.tar.gz"
URL="$BASE/$ASSET"

TMP="$(mktemp -d)"
trap 'rm -rf "$TMP"' EXIT

# Download archive.
ARCHIVE="$TMP/$ASSET"
echo "Downloading $ASSET..."
curl -fsSL "$URL" -o "$ARCHIVE"

# Verify sha256 from SHA256SUMS (best-effort: proceed if the file is missing).
SUMS="$TMP/SHA256SUMS"
if curl -fsSL "$BASE/SHA256SUMS" -o "$SUMS"; then
  expected="$(grep -E "[[:space:]]+${ASSET}\$" "$SUMS" | awk '{print $1}' | head -n1 || true)"
  if [ -n "$expected" ]; then
    if command -v sha256sum >/dev/null; then
      actual="$(sha256sum "$ARCHIVE" | awk '{print $1}')"
    elif command -v shasum >/dev/null; then
      actual="$(shasum -a 256 "$ARCHIVE" | awk '{print $1}')"
    else
      actual=""
    fi
    if [ -n "$actual" ]; then
      [ "$actual" = "$expected" ] || die "checksum mismatch (expected $expected, got $actual)"
      echo "Checksum OK."
    fi
  fi
fi

# Install: extract into a per-version dir, repoint current + launcher symlinks.
dest="$INSTALL_DIR/versions/$version"
rm -rf "$dest"
mkdir -p "$dest"
# Archives contain a top-level codegraph-<target>/ dir; strip it.
tar -xzf "$ARCHIVE" -C "$dest" --strip-components=1

mkdir -p "$BIN_DIR"
ln -sf "$dest/bin/codegraph" "$BIN_DIR/codegraph"
ln -sfn "$dest" "$INSTALL_DIR/current"
echo "Installed   $dest"
echo "Linked      $BIN_DIR/codegraph -> $dest/bin/codegraph"

# Prune older version dirs so the vendored Node runtime doesn't pile up.
pruned=0
if [ -d "$INSTALL_DIR/versions" ]; then
  for d in "$INSTALL_DIR/versions"/*; do
    [ -d "$d" ] || continue
    if [ "$d" != "$dest" ] && rm -rf "$d"; then
      pruned=$((pruned + 1))
    fi
  done
fi
[ "$pruned" -gt 0 ] && echo "Removed     $pruned older version(s)"

echo ""
"$BIN_DIR/codegraph" --version 2>/dev/null || true
