#!/bin/sh

pactl load-module module-null-sink sink_name=VirtualSink sink_properties=device.description=VirtualSink

pactl load-module module-null-sink media.class=Audio/Source/Virtual sink_name=VirtualMic channel_map=front-left,front-right

pw-link VirtualSink:monitor_FL VirtualMic:input_FL

pw-link VirtualSink:monitor_FR VirtualMic:input_FR
